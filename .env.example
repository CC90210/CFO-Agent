# ─────────────────────────────────────────────
#  ATLAS TRADING AGENT — Environment Template
#  Copy to .env and fill in real values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────

# ── AI ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Exchange ─────────────────────────────────
DEFAULT_EXCHANGE=binance
EXCHANGE_API_KEY=your_exchange_api_key_here
EXCHANGE_SECRET=your_exchange_secret_here
# Optional: passphrase required by some exchanges (e.g. OKX, KuCoin)
EXCHANGE_PASSPHRASE=

# ── Telegram Notifications ───────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
# CC's Telegram user ID — only this user can control the bot.
# Leave blank on first run: the bot will auto-register the first user who messages it.
TELEGRAM_USER_ID=

# ── Database ─────────────────────────────────
# SQLite (default, file lives in project root)
DATABASE_URL=sqlite:///trading_agent.db
# PostgreSQL example:
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/atlas

# ── Safety Flags ─────────────────────────────
# Set PAPER_TRADE=false only when you are 100% ready for live execution
PAPER_TRADE=true
# CONFIRM_LIVE=true  # must be explicitly set to allow live orders

# ── Risk Controls ─────────────────────────────
# Stop trading if total drawdown exceeds this % from equity peak
MAX_DRAWDOWN_PCT=15
# Stop trading for the rest of the day if daily loss exceeds this %
DAILY_LOSS_LIMIT_PCT=5
# Risk this % of account equity per individual trade
PER_TRADE_RISK_PCT=1.5
# Maximum number of simultaneous open positions
MAX_OPEN_POSITIONS=5

# ── Autonomous Daemon Schedule ────────────────
# Interval for quick watchlist scans (minutes)
SCAN_INTERVAL_MINUTES=15
# Interval for full multi-agent deep analysis (hours)
DEEP_ANALYSIS_INTERVAL_HOURS=1
# Interval for portfolio rebalance evaluation (hours)
REBALANCE_CHECK_HOURS=4
# Trading mode for the autonomous daemon: paper or live
AUTONOMOUS_MODE=paper

# ── Logging ───────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs/
